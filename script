#!/usr/bin/env bash
# sk - 一键多功能脚本菜单
# 保存为 /usr/local/bin/sk 并执行: chmod +x /usr/local/bin/sk

set -euo pipefail

# ---------- 颜色定义 ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# ---------- 基础工具 ----------
is_cmd() { command -v "$1" >/dev/null 2>&1; }

require_root() {
  if [ "$(id -u)" -ne 0 ]; then
    echo -e "${RED}请使用 root 运行此脚本（sudo -i 或者 su）${NC}"
    exit 1
  fi
}

PM=""
detect_pm() {
  if is_cmd apt-get; then PM="apt"; fi
  if is_cmd dnf; then PM="dnf"; fi
  if is_cmd yum && [ -z "$PM" ]; then PM="yum"; fi
  if is_cmd zypper && [ -z "$PM" ]; then PM="zypper"; fi
  if is_cmd pacman && [ -z "$PM" ]; then PM="pacman"; fi
}

pkg_install() {
  case "$PM" in
    apt)
      apt-get update -y
      DEBIAN_FRONTEND=noninteractive apt-get install -y "$@"
      ;;
    dnf) dnf install -y "$@" ;;
    yum) yum install -y "$@" ;;
    zypper) zypper --non-interactive install -y "$@" ;;
    pacman) pacman -Sy --noconfirm "$@" ;;
    *) echo -e "${YELLOW}未识别的包管理器，无法安装 $*${NC}"; return 1 ;;
  esac
}

# ---------- 1. 安装 3x-ui ----------
install_3xui() {
  require_root
  echo -e "${GREEN}开始安装 3x-ui...${NC}"
  bash <(curl -Ls https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh)
}

# ---------- 2. 安装 x-ui ----------
install_xui() {
  require_root
  echo -e "${GREEN}开始安装 x-ui...${NC}"
  bash <(curl -Ls https://raw.githubusercontent.com/FranzKafkaYu/x-ui/master/install.sh)
}

# ---------- 3. Caddy 相关 ----------
caddy_arch_map() {
  local uarch
  uarch="$(uname -m)"
  case "$uarch" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    armv7l|armv7) echo "armv7" ;;
    armv6l|armv6) echo "armv6" ;;
    *) echo "" ;;
  esac
}

install_caddy_repo_deb() {
  pkg_install debian-keyring debian-archive-keyring apt-transport-https curl gnupg
  install -d -m 0755 /etc/apt/keyrings
  curl -fsSL https://dl.cloudsmith.io/public/caddy/stable/gpg.key | gpg --dearmor -o /etc/apt/keyrings/caddy-stable.gpg
  curl -fsSL https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt \
    | sed 's#deb #[signed-by=/etc/apt/keyrings/caddy-stable.gpg] deb #' \
    | tee /etc/apt/sources.list.d/caddy-stable.list >/dev/null
  apt-get update -y
  apt-get install -y caddy
}

install_caddy_repo_rpm() {
  if is_cmd dnf; then
    dnf -y install 'dnf-command(copr)' || true
    dnf -y copr enable @caddy/caddy || true
    dnf -y install caddy
  else
    return 1
  fi
}

install_caddy_binary() {
  local arch; arch="$(caddy_arch_map)"
  if [ -z "$arch" ]; then
    echo -e "${RED}不支持的架构: $(uname -m)，请手动安装 Caddy。${NC}"
    return 1
  fi
  pkg_install curl tar ca-certificates || true
  mkdir -p /usr/local/bin
  echo -e "${GREEN}下载并安装 Caddy 二进制...${NC}"
  curl -fsSL "https://caddyserver.com/api/download?os=linux&arch=${arch}&id=caddy" | tar -xz -C /usr/local/bin caddy
  chmod +x /usr/local/bin/caddy
  
  # 创建 systemd 服务
  cat > /etc/systemd/system/caddy.service <<EOF
[Unit]
Description=Caddy
Documentation=https://caddyserver.com/docs/
After=network.target network-online.target
Requires=network-online.target

[Service]
User=root
Group=root
ExecStart=/usr/local/bin/caddy run --environ --config /etc/caddy/Caddyfile
ExecReload=/usr/local/bin/caddy reload --config /etc/caddy/Caddyfile
TimeoutStopSec=5s
LimitNOFILE=1048576
LimitNPROC=512
PrivateTmp=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
EOF
  
  mkdir -p /etc/caddy
  systemctl daemon-reload
  systemctl enable caddy
  echo -e "${GREEN}Caddy 二进制安装完成！${NC}"
}

install_caddy() {
  require_root
  detect_pm
  echo -e "${GREEN}开始安装 Caddy...${NC}"
  
  if [ "$PM" = "apt" ]; then
    install_caddy_repo_deb
  elif [ "$PM" = "dnf" ] || [ "$PM" = "yum" ]; then
    if ! install_caddy_repo_rpm; then
      echo -e "${YELLOW}RPM 仓库安装失败，尝试二进制安装...${NC}"
      install_caddy_binary
    fi
  else
    echo -e "${YELLOW}使用二进制安装...${NC}"
    install_caddy_binary
  fi
  
  if is_cmd caddy; then
    echo -e "${GREEN}Caddy 安装成功！版本: $(caddy version)${NC}"
  else
    echo -e "${RED}Caddy 安装失败！${NC}"
  fi
}

caddy_reverse_proxy() {
  require_root
  if ! is_cmd caddy; then
    echo -e "${RED}请先安装 Caddy！${NC}"
    return 1
  fi
  
  echo -e "${CYAN}=== Caddy 一键反代配置 ===${NC}"
  read -p "请输入域名（如 example.com）: " domain
  read -p "请输入后端 IP（支持 IPv4/IPv6，如 127.0.0.1 或 [::1]）: " backend_ip
  read -p "请输入后端端口: " backend_port
  
  # 判断是否为 IPv6 地址
  if [[ "$backend_ip" =~ ^\[.*\]$ ]]; then
    # 已经是 [IPv6] 格式
    upstream="${backend_ip}:${backend_port}"
  elif [[ "$backend_ip" =~ : ]]; then
    # 包含冒号，可能是 IPv6 地址
    upstream="[${backend_ip}]:${backend_port}"
  else
    # IPv4 地址
    upstream="${backend_ip}:${backend_port}"
  fi
  
  # 创建 Caddyfile
  cat > /etc/caddy/Caddyfile <<EOF
${domain} {
    reverse_proxy ${upstream}
    encode gzip
    header {
        -Server
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer-when-downgrade
    }
}
EOF
  
  # 重启 Caddy
  systemctl restart caddy
  echo -e "${GREEN}反代配置完成！${NC}"
  echo -e "${YELLOW}域名: ${domain} -> ${upstream}${NC}"
  echo -e "${YELLOW}Caddy 配置文件: /etc/caddy/Caddyfile${NC}"
}

uninstall_caddy() {
  require_root
  echo -e "${RED}开始卸载 Caddy...${NC}"
  
  systemctl stop caddy 2>/dev/null || true
  systemctl disable caddy 2>/dev/null || true
  rm -f /etc/systemd/system/caddy.service
  systemctl daemon-reload
  
  detect_pm
  case "$PM" in
    apt) apt-get remove -y caddy ;;
    dnf) dnf remove -y caddy ;;
    yum) yum remove -y caddy ;;
    zypper) zypper remove -y caddy ;;
    pacman) pacman -R --noconfirm caddy ;;
    *) 
      rm -f /usr/local/bin/caddy
      rm -rf /etc/caddy
      rm -rf /var/lib/caddy
      ;;
  esac
  
  echo -e "${GREEN}Caddy 卸载完成！${NC}"
}

caddy_menu() {
  while true; do
    echo -e "\n${CYAN}=== Caddy 菜单 ===${NC}"
    echo "1) 安装 Caddy"
    echo "2) 一键反代配置"
    echo "3) 卸载 Caddy"
    echo "0) 返回主菜单"
    read -p "请选择 [0-3]: " caddy_choice
    
    case $caddy_choice in
      1) install_caddy ;;
      2) caddy_reverse_proxy ;;
      3) uninstall_caddy ;;
      0) break ;;
      *) echo -e "${RED}无效选择！${NC}" ;;
    esac
  done
}

# ---------- 4. Warp 相关 ----------
warp_install() {
  require_root
  echo -e "${GREEN}开始安装 Warp...${NC}"
  wget -N https://gitlab.com/fscarmen/warp/-/raw/main/menu.sh && bash menu.sh
}

warp_menu() {
  if ! is_cmd warp; then
    echo -e "${YELLOW}Warp 未安装，请先安装！${NC}"
    return
  fi
  
  while true; do
    echo -e "\n${CYAN}=== Warp 菜单 ===${NC}"
    echo "1) 添加 IPv4"
    echo "2) 添加 IPv6"
    echo "3) 添加双栈"
    echo "4) 开关 Warp"
    echo "5) 卸载 Warp"
    echo "0) 返回主菜单"
    read -p "请选择 [0-5]: " warp_choice
    
    case $warp_choice in
      1) warp 4 ;;
      2) warp 6 ;;
      3) warp d ;;
      4) warp o ;;
      5) warp u ;;
      0) break ;;
      *) echo -e "${RED}无效选择！${NC}" ;;
    esac
  done
}

# ---------- 5. Komari 相关 ----------
install_komari() {
  require_root
  echo -e "${GREEN}开始安装 Komari...${NC}"
  curl -fsSL https://raw.githubusercontent.com/komari-monitor/komari/main/install-komari.sh -o install-komari.sh
  chmod +x install-komari.sh
  sudo ./install-komari.sh
}

uninstall_komari() {
  require_root
  echo -e "${RED}开始卸载 Komari...${NC}"
  echo "1) 官方卸载"
  echo "2) Agent 卸载"
  read -p "请选择卸载方式 [1-2]: " komari_uninstall_choice
  
  case $komari_uninstall_choice in
    1)
      if [ -f "install-komari.sh" ]; then
        sudo ./install-komari.sh
      else
        echo -e "${YELLOW}未找到 install-komari.sh，请先下载脚本${NC}"
        curl -fsSL https://raw.githubusercontent.com/komari-monitor/komari/main/install-komari.sh -o install-komari.sh
        chmod +x install-komari.sh
        sudo ./install-komari.sh
      fi
      ;;
    2)
      sudo systemctl stop komari-agent
      sudo systemctl disable komari-agent
      sudo rm -f /etc/systemd/system/komari-agent.service
      sudo systemctl daemon-reload
      sudo rm -rf /opt/komari/agent /var/log/komari
      echo -e "${GREEN}Komari Agent 卸载完成！${NC}"
      ;;
    *)
      echo -e "${RED}无效选择！${NC}"
      ;;
  esac
}

komari_menu() {
  while true; do
    echo -e "\n${CYAN}=== Komari 菜单 ===${NC}"
    echo "1) 安装 Komari"
    echo "2) 卸载 Komari"
    echo "0) 返回主菜单"
    read -p "请选择 [0-2]: " komari_choice
    
    case $komari_choice in
      1) install_komari ;;
      2) uninstall_komari ;;
      0) break ;;
      *) echo -e "${RED}无效选择！${NC}" ;;
    esac
  done
}

# ---------- 6. Docker 安装 ----------
install_docker() {
  require_root
  detect_pm
  echo -e "${GREEN}开始安装 Docker...${NC}"
  
  # 卸载旧版本
  case "$PM" in
    apt)
      apt-get remove -y docker docker-engine docker.io containerd runc 2>/dev/null || true
      ;;
    dnf|yum)
      dnf remove -y docker docker-client docker-client-latest docker-common docker-latest docker-latest-logrotate docker-logrotate docker-engine 2>/dev/null || true
      ;;
  esac
  
  # 安装依赖
  pkg_install apt-transport-https ca-certificates curl gnupg lsb-release
  
  # 添加 Docker GPG 密钥
  install -m 0755 -d /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  chmod a+r /etc/apt/keyrings/docker.gpg
  
  # 添加 Docker 仓库
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null
  
  # 安装 Docker
  apt-get update
  apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  
  # 启动并设置开机自启
  systemctl start docker
  systemctl enable docker
  
  # 测试安装
  if docker --version; then
    echo -e "${GREEN}Docker 安装成功！${NC}"
    echo -e "${YELLOW}版本: $(docker --version)${NC}"
  else
    echo -e "${RED}Docker 安装失败！${NC}"
  fi
}

# ---------- 主菜单 ----------
main_menu() {
  while true; do
    echo -e "\n${PURPLE}=== 一键脚本菜单 ===${NC}"
    echo "1) 安装 3x-ui"
    echo "2) 安装 x-ui"
    echo "3) Caddy 相关"
    echo "4) Warp 相关"
    echo "5) Komari 相关"
    echo "6) 安装 Docker"
    echo "0) 退出"
    read -p "请选择 [0-6]: " main_choice
    
    case $main_choice in
      1) install_3xui ;;
      2) install_xui ;;
      3) caddy_menu ;;
      4) 
        if ! is_cmd warp; then
          warp_install
        else
          warp_menu
        fi
        ;;
      5) komari_menu ;;
      6) install_docker ;;
      0) 
        echo -e "${GREEN}再见！${NC}"
        exit 0
        ;;
      *) echo -e "${RED}无效选择！${NC}" ;;
    esac
  done
}

# ---------- 脚本入口 ----------
if [ "$#" -eq 0 ]; then
  main_menu
else
  # 支持命令行参数直接调用
  case "$1" in
    1|3xui) install_3xui ;;
    2|x-ui) install_xui ;;
    3|caddy) caddy_menu ;;
    4|warp) 
      if ! is_cmd warp; then
        warp_install
      else
        warp_menu
      fi
      ;;
    5|komari) komari_menu ;;
    6|docker) install_docker ;;
    *) 
      echo "用法: sk [选项]"
      echo "选项:"
      echo "  1 或 3xui   安装 3x-ui"
      echo "  2 或 x-ui   安装 x-ui"
      echo "  3 或 caddy  Caddy 菜单"
      echo "  4 或 warp   Warp 菜单"
      echo "  5 或 komari Komari 菜单"
      echo "  6 或 docker 安装 Docker"
      echo "  无参数      显示主菜单"
      ;;
  esac
fi
